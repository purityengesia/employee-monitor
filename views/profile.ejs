<%- include('partials/header', { title: 'My Profile', page: 'profile', employer, alertCount: 0 }) %>

<div class="form-page-wrap">
  <div class="card form-card" style="max-width:580px">
    <div class="card-header">
      <h2>My Profile</h2>
      <p class="card-sub">Update your name, username and password</p>
    </div>
    <div class="form-body">

      <!-- Current info display -->
      <div class="profile-banner">
        <div class="profile-avatar-lg"><%= employer.name.charAt(0) %></div>
        <div>
          <div class="profile-name"><%= employer.name %></div>
          <div class="profile-username">@<%= admin.username %></div>
          <div class="profile-role-tag">Administrator</div>
        </div>
      </div>

      <% if (success) { %>
        <div class="alert-box success">✓ <%= success %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert-box error">✗ <%= error %></div>
      <% } %>

      <form method="POST" action="/profile">
        <div class="settings-section" style="padding: 0; border:none; margin-bottom:20px">
          <h3 style="margin-bottom:14px">Account Details</h3>
          <div class="form-group">
            <label>Full Name</label>
            <input type="text" name="fullName" value="<%= admin.name %>" placeholder="Your full name" required />
          </div>
          <div class="form-group">
            <label>Username</label>
            <input type="text" name="username" value="<%= admin.username %>" placeholder="Login username" required />
          </div>
        </div>

        <div class="settings-section" style="padding: 0; border:none; margin-bottom:24px">
          <h3 style="margin-bottom:14px">Change Password</h3>
          <div class="form-group">
            <label>Current Password <span class="required">*required</span></label>
            <input type="password" name="currentPassword" placeholder="Enter your current password" required />
          </div>
          <div class="form-group">
            <label>New Password <span class="optional">(leave blank to keep current)</span></label>
            <input type="password" name="newPassword" placeholder="Enter new password" id="newPass" />
          </div>
          <div class="form-group">
            <label>Confirm New Password</label>
            <input type="password" name="confirmPassword" placeholder="Repeat new password" id="confirmPass" />
          </div>
          <div class="password-match" id="matchMsg"></div>
        </div>

        <div class="form-actions">
          <a href="/" class="btn-cancel">Cancel</a>
          <button type="submit" class="btn-primary">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
// Live password match check
const newPass = document.getElementById('newPass');
const confirmPass = document.getElementById('confirmPass');
const matchMsg = document.getElementById('matchMsg');

function checkMatch() {
  if (!newPass.value && !confirmPass.value) { matchMsg.textContent = ''; return; }
  if (newPass.value === confirmPass.value) {
    matchMsg.textContent = '✓ Passwords match';
    matchMsg.className = 'password-match ok';
  } else {
    matchMsg.textContent = '✗ Passwords do not match';
    matchMsg.className = 'password-match fail';
  }
}
newPass.addEventListener('input', checkMatch);
confirmPass.addEventListener('input', checkMatch);
</script>

<%- include('partials/footer') %>
