<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %> — WorkWatch</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="sidebar-overlay" id="overlay" onclick="closeSidebar()"></div>
  <div class="app-shell">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-logo">
        <span class="logo-icon">◈</span>
        <span class="logo-text">WorkWatch</span>
      </div>
      <nav class="sidebar-nav">
        <a href="/" class="nav-item <%= page === 'dashboard' ? 'active' : '' %>">
          <span class="nav-icon">⊡</span> Dashboard
        </a>
        <a href="/employees" class="nav-item <%= page === 'employees' ? 'active' : '' %>">
          <span class="nav-icon">◉</span> Employees
        </a>
        <a href="/activity" class="nav-item <%= page === 'activity' ? 'active' : '' %>">
          <span class="nav-icon">◈</span> Activity Log
        </a>
        <a href="/alerts" class="nav-item <%= page === 'alerts' ? 'active' : '' %>">
          <span class="nav-icon">◬</span> Alerts
          <% if (typeof alertCount !== 'undefined' && alertCount > 0) { %>
            <span class="badge"><%= alertCount %></span>
          <% } %>
        </a>
        <a href="/settings" class="nav-item <%= page === 'settings' ? 'active' : '' %>">
          <span class="nav-icon">⊕</span> Settings
        </a>
      </nav>
      <div class="sidebar-footer">
        <a href="/profile" class="employer-info-link">
          <div class="employer-info">
            <div class="employer-avatar"><%- employer.name.charAt(0) %></div>
            <div>
              <div class="employer-name"><%= employer.name %></div>
              <div class="employer-role">Edit Profile →</div>
            </div>
          </div>
        </a>
        <a href="/logout" class="logout-btn">⏻ Logout</a>
      </div>
    </aside>
    <main class="main-content">
      <div class="top-bar">
        <div style="display:flex;align-items:center;gap:12px">
          <button class="menu-toggle" onclick="toggleSidebar()">☰</button>
          <h1 class="page-title"><%= title %></h1>
        </div>
        <div class="top-bar-right">
          <div class="live-indicator"><span class="pulse"></span> Live</div>
          <div class="clock" id="clock"></div>
        </div>
      </div>
      <div class="content-body">
